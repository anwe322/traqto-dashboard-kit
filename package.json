{
  "name": "@traqto/dashboard-kit",
  "version": "0.1.0",
  "description": "Interactive, reusable dashboard kit for all traqto products",
  "type": "module",
  "main": "./dist/dashboard-kit.umd.cjs",
  "module": "./dist/dashboard-kit.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/dashboard-kit.js",
      "require": "./dist/dashboard-kit.umd.cjs"
    },
    "./styles.css": "./dist/dashboard-kit.css"
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "dev": "vite --config examples/playground/vite.config.ts",
    "build": "tsc -p tsconfig.build.json && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "recharts": "^2.15.0",
    "react-grid-layout": "^1.5.0",
    "react-resizable": "^3.0.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-grid-layout": "^1.3.5",
    "@types/react-resizable": "^3.0.8",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.4.0"
  }
}
